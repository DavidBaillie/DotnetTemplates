{
  "$schema": "http://json.schemastore.org/template",
  "author": "David Baillie",
  "classifications": ["Web", "API", "Minimal API"],
  "identity": "MinimalApi.Template",
  "name": "Minimal API Template",
  "shortName": "minapi",
  "sourceName": "ExampleTemplate",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "symbols": {
    "includeAuth": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Include JWT authentication and authorization."
    },
    "usePostgreSql": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "If the PostgreSQL App Db Context should be included."
    },
    "testWithPostgreSql": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "If the PostgreSQL App Db Context should be used for testing, and this a database using local Docker should be configured for tests"
    },
    "requireApiKey": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "If communication with the API should require an API Key be provider in each request header."
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            ".template.config/**",
            "**/bin/**",
            "**/obj/**",
            "**/*.user"
          ]
        },
        {
          "condition": "(!includeAuth)",
          "exclude": [
            "ExampleTemplate.WebApp.Tests/Setup/Authentication/**"
          ]
        },
        {
          "condition": "(!usePostgreSql)",
          "exclude": [
            "ExampleTemplate.WebApp/Database/PostgreSql/**"
          ]
        },
        {
          "condition": "(!testWithPostgreSql)",
          "exclude": [
            "ExampleTemplate.WebApp/Database/PostgreSql/**"
          ]
        },
        {
          "condition": "(!requireApiKey)",
          "exclude": [
            "ExampleTemplate.WebApp/Middleware/ApiKeyMiddleware.cs"
          ]
        }
      ]
    }
  ]
}
